# Copy this file to .env and fill in your values
# cp .env.example .env

# GCP project and storage
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket-name

# Path to the service account key file written by terraform apply
# Check terraform/main.tf (local_file.airflow_sa_key_file) for the exact output location
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-sa.json

# Airflow security keys (local Docker Compose only)
# Note: production GKE uses the keys set in k8s/helm/values.yaml
#
# FERNET_KEY — encrypts sensitive data in the Airflow database (connections, variables).
#              All Airflow instances sharing the same database must use the same fernet key.
#              Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# SECRET_KEY — signs Flask sessions for the Airflow webserver.
#              Without it users cannot log in to the UI.
#              Generate: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__CORE__FERNET_KEY=your-fernet-key
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key

# Airflow Variables (used by the DAG)
AIRFLOW_VAR_GCP_PROJECT_ID=your-gcp-project-id
AIRFLOW_VAR_GCS_BUCKET=your-gcs-bucket-name
AIRFLOW_VAR_GCS_PREFIX=raw/orders
AIRFLOW_VAR_GCS_FILENAME=orders.csv
AIRFLOW_VAR_BQ_DATASET=raw
AIRFLOW_VAR_BQ_TABLE=orders